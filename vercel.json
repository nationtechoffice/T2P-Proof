
{
  "version": 2,
  "cleanUrls": true,
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/dashboard", "dest": "/public/dashboard.html" },
    { "src": "/add-project", "dest": "/add-project.html" },
    { "src": "/privacy", "dest": "/privacy.html" },
    { "src": "/terms", "dest": "/terms.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
