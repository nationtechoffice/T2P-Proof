# Pi Developer Portal — server-side Platform API key (never expose in client code)
PI_API_KEY=your_pi_developer_api_key_here

# Pi Sign-in OAuth — public client ID from Developer Portal → Pi Sign-in section
NEXT_PUBLIC_PI_OAUTH_CLIENT_ID=your_pi_oauth_client_id_here

# Optional: override callback URL (defaults to https://yourdomain/signin/callback)
# NEXT_PUBLIC_PI_OAUTH_REDIRECT_URI=https://t2pproof.link/signin/callback
